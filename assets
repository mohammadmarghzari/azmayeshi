:root{

--bg:#0b1220;
--card:#162033;
--blue:#1e90ff;
--text:#ffffff;

}

body{
background:var(--bg);
color:var(--text);
}

.metric-card{
background:var(--card);
border-radius:16px;
padding:20px;
box-shadow:0 8px 30px rgba(0,0,0,.25);
}

.glass{

background:rgba(255,255,255,.08);

backdrop-filter:blur(12px);

border:1px solid rgba(255,255,255,.1);

border-radius:18px;

}

h1,h2,h3{

color:white;

}